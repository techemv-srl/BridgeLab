{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Default capability for BridgeLab",
	"windows": ["main", "bridgelab-help"],
	"permissions": [
		"core:default",
		"core:window:default",
		"core:window:allow-create",
		"core:window:allow-close",
		"core:webview:default",
		"core:webview:allow-create-webview-window",
		"core:event:default",
		"dialog:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"fs:default",
		"fs:allow-read-text-file",
		"fs:allow-write-text-file",
		"updater:default"
	]
}
