{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "BridgeLab",
	"version": "0.1.0",
	"identifier": "com.bridgelab.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "BridgeLab",
				"width": 1400,
				"height": 900,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"category": "DeveloperTool",
		"shortDescription": "Modern HL7/FHIR message editor",
		"longDescription": "BridgeLab is a professional HL7/FHIR message editor for healthcare integration. It handles large messages (5-10MB with base64 payloads), MLLP/HTTP transport with listener support, anonymization, validation against the HL7 standard, FHIR Bundle visualization and FHIRPath evaluation. Multi-language UI (EN, IT, FR, ES, DE).",
		"copyright": "Copyright (c) 2026 TECHEMV SRL — info@techemv.it",
		"publisher": "TECHEMV SRL",
		"homepage": "https://www.techemv.it",
		"license": "MIT",
		"licenseFile": "../LICENSE",
		"fileAssociations": [
			{
				"ext": ["hl7"],
				"name": "HL7 Message",
				"description": "HL7 v2.x message",
				"role": "Editor"
			}
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"windows": {
			"webviewInstallMode": { "type": "offlineInstaller" },
			"nsis": {
				"installMode": "both",
				"installerIcon": "icons/icon.ico",
				"headerImage": "icons/nsis/header.bmp",
				"sidebarImage": "icons/nsis/sidebar.bmp",
				"displayLanguageSelector": true,
				"languages": ["English", "Italian", "French", "Spanish", "German"],
				"compression": "lzma"
			},
			"wix": {
				"language": ["en-US", "it-IT", "fr-FR", "es-ES", "de-DE"]
			}
		},
		"macOS": {
			"minimumSystemVersion": "10.15",
			"dmg": {
				"windowSize": { "width": 660, "height": 400 },
				"appPosition":  { "x": 180, "y": 170 },
				"applicationFolderPosition": { "x": 480, "y": 170 }
			}
		},
		"linux": {
			"deb": {
				"depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
				"section": "utils",
				"priority": "optional"
			},
			"appimage": {
				"bundleMediaFramework": true
			},
			"rpm": {
				"depends": ["webkit2gtk4.1", "gtk3"]
			}
		}
	},
	"plugins": {
		"updater": {
			"active": true,
			"dialog": true,
			"pubkey": "PLACEHOLDER_GENERATE_WITH_TAURI_SIGNER",
			"endpoints": [
				"https://github.com/techemv-srl/BridgeLab/releases/latest/download/latest.json"
			]
		}
	}
}
